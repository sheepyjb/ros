<?xml version="1.0"?>
<sdf version="1.10">
  <world name="diffbot_drive_world">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    <atmosphere type="adiabatic"/>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.72 0.72 0.72 1</ambient>
            <diffuse>0.72 0.72 0.72 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="diffbot">
      <pose>0 0 0 0 0 0</pose>

      <link name="base_link">
        <pose>0 0 0.16 0 0 0</pose>
        <inertial>
          <mass>4.0</mass>
          <inertia>
            <ixx>0.04</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.08</iyy>
            <iyz>0</iyz>
            <izz>0.10</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.42 0.30 0.16</size>
            </box>
          </geometry>
          <material>
            <ambient>0.05 0.20 0.80 1</ambient>
            <diffuse>0.05 0.20 0.80 1</diffuse>
            <specular>0.10 0.10 0.10 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.42 0.30 0.16</size>
            </box>
          </geometry>
        </collision>
      </link>

      <link name="left_wheel_link">
        <pose>0 0.18 0.07 0 0 0</pose>
        <inertial>
          <mass>0.35</mass>
          <inertia>
            <ixx>0.001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.001</iyy>
            <iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.04 0.04 0.04 1</ambient>
            <diffuse>0.04 0.04 0.04 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <link name="right_wheel_link">
        <pose>0 -0.18 0.07 0 0 0</pose>
        <inertial>
          <mass>0.35</mass>
          <inertia>
            <ixx>0.001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.001</iyy>
            <iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.04 0.04 0.04 1</ambient>
            <diffuse>0.04 0.04 0.04 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <link name="caster_link">
        <pose>-0.16 0 0.035 0 0 0</pose>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.0001</iyy>
            <iyz>0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.08 0.08 0.08 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
        </collision>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>left_wheel_link</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>right_wheel_link</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="caster_joint" type="ball">
        <parent>base_link</parent>
        <child>caster_link</child>
      </joint>

      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.36</wheel_separation>
        <wheel_radius>0.07</wheel_radius>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <odom_publish_frequency>30</odom_publish_frequency>
        <max_linear_velocity>0.6</max_linear_velocity>
        <min_linear_velocity>-0.3</min_linear_velocity>
        <max_angular_velocity>1.2</max_angular_velocity>
        <min_angular_velocity>-1.2</min_angular_velocity>
      </plugin>
    </model>
  </world>
</sdf>
