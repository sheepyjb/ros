<?xml version="1.0"?>
<sdf version="1.10">
  <world name="diffbot_sensors_world">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    <atmosphere type="adiabatic"/>

    <scene>
      <ambient>0.65 0.65 0.65</ambient>
      <background>0.78 0.82 0.86</background>
      <grid>true</grid>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.72 0.72 0.72 1</ambient>
            <diffuse>0.72 0.72 0.72 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="front_box">
      <static>true</static>
      <pose>2.2 0 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.45 0.80 0.50</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.45 0.80 0.50</size>
            </box>
          </geometry>
          <material>
            <ambient>0.80 0.18 0.12 1</ambient>
            <diffuse>0.80 0.18 0.12 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="left_cylinder">
      <static>true</static>
      <pose>1.4 0.9 0.30 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>0.60</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>0.60</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.10 0.55 0.30 1</ambient>
            <diffuse>0.10 0.55 0.30 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="diffbot">
      <pose>0 0 0 0 0 0</pose>

      <link name="base_link">
        <pose>0 0 0.16 0 0 0</pose>
        <inertial>
          <mass>4.0</mass>
          <inertia>
            <ixx>0.04</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.08</iyy>
            <iyz>0</iyz>
            <izz>0.10</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.42 0.30 0.16</size>
            </box>
          </geometry>
          <material>
            <ambient>0.05 0.20 0.80 1</ambient>
            <diffuse>0.05 0.20 0.80 1</diffuse>
            <specular>0.10 0.10 0.10 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.42 0.30 0.16</size>
            </box>
          </geometry>
        </collision>
      </link>

      <link name="left_wheel_link">
        <pose>0 0.18 0.07 0 0 0</pose>
        <inertial>
          <mass>0.35</mass>
          <inertia>
            <ixx>0.001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.001</iyy>
            <iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.04 0.04 0.04 1</ambient>
            <diffuse>0.04 0.04 0.04 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <link name="right_wheel_link">
        <pose>0 -0.18 0.07 0 0 0</pose>
        <inertial>
          <mass>0.35</mass>
          <inertia>
            <ixx>0.001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.001</iyy>
            <iyz>0</iyz>
            <izz>0.001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.04 0.04 0.04 1</ambient>
            <diffuse>0.04 0.04 0.04 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.07</radius>
              <length>0.05</length>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1.0</mu>
                <mu2>1.0</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
      </link>

      <link name="front_caster_link">
        <pose>0.16 0 0.035 0 0 0</pose>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.0001</iyy>
            <iyz>0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.08 0.08 0.08 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
        </collision>
      </link>

      <link name="rear_caster_link">
        <pose>-0.16 0 0.035 0 0 0</pose>
        <inertial>
          <mass>0.1</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.0001</iyy>
            <iyz>0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.08 0.08 0.08 1</ambient>
            <diffuse>0.08 0.08 0.08 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <collision name="collision">
          <geometry>
            <sphere>
              <radius>0.035</radius>
            </sphere>
          </geometry>
        </collision>
      </link>

      <link name="laser_link">
        <pose>0.06 0 0.25 0 0 0</pose>
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.0001</iyy>
            <iyz>0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.055</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.80 0.08 0.08 1</ambient>
            <diffuse>0.80 0.08 0.08 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <sensor name="front_lidar" type="gpu_lidar">
          <topic>/scan</topic>
          <update_rate>10</update_rate>
          <lidar>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-1.5708</min_angle>
                <max_angle>1.5708</max_angle>
              </horizontal>
              <vertical>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.08</min>
              <max>8.0</max>
              <resolution>0.01</resolution>
            </range>
          </lidar>
          <always_on>true</always_on>
          <visualize>true</visualize>
        </sensor>
      </link>

      <link name="camera_link">
        <pose>0.22 0 0.20 0 0 0</pose>
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.0001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.0001</iyy>
            <iyz>0</iyz>
            <izz>0.0001</izz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.06 0.09 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.05 0.65 0.30 1</ambient>
            <diffuse>0.05 0.65 0.30 1</diffuse>
            <specular>0.20 0.20 0.20 1</specular>
          </material>
        </visual>
        <sensor name="front_camera" type="camera">
          <topic>/camera/image_raw</topic>
          <update_rate>15</update_rate>
          <camera>
            <camera_info_topic>/camera/camera_info</camera_info_topic>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>320</width>
              <height>240</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.05</near>
              <far>20.0</far>
            </clip>
            <optical_frame_id>camera_optical_frame</optical_frame_id>
          </camera>
          <always_on>true</always_on>
          <visualize>true</visualize>
        </sensor>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>left_wheel_link</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent>
        <child>right_wheel_link</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="front_caster_joint" type="ball">
        <parent>base_link</parent>
        <child>front_caster_link</child>
      </joint>

      <joint name="rear_caster_joint" type="ball">
        <parent>base_link</parent>
        <child>rear_caster_link</child>
      </joint>

      <joint name="laser_joint" type="fixed">
        <parent>base_link</parent>
        <child>laser_link</child>
      </joint>

      <joint name="camera_joint" type="fixed">
        <parent>base_link</parent>
        <child>camera_link</child>
      </joint>

      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.36</wheel_separation>
        <wheel_radius>0.07</wheel_radius>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <odom_publish_frequency>30</odom_publish_frequency>
        <max_linear_velocity>0.6</max_linear_velocity>
        <min_linear_velocity>-0.3</min_linear_velocity>
        <max_angular_velocity>1.2</max_angular_velocity>
        <min_angular_velocity>-1.2</min_angular_velocity>
      </plugin>
    </model>
  </world>
</sdf>
